{
    "name": "TfSwitch CLI",
    "id": "tfswitch",
    "version": "0.0.1",
    "description": "TFSwitch CLI allows you to manage local Terraform version",
    "documentationURL": "https://github.com/yousysadmin/devcontainer-features/tfswitch",
    "installsAfter": [
        "ghcr.io/yousysadmin/devcontainer-features/common-utils"
    ],
    "options": {
        "version": {
            "type": "string",
            "proposals": [
                "v1.1.1",
                "latest"
            ],
            "default": "latest",
            "description": "Select the TFSwitch version you would like to install"
        }
    }
}
