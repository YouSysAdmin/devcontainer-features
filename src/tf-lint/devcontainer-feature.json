{
    "name": "TFLint CLI",
    "id": "tflint-cli",
    "version": "0.0.1",
    "description": "Terraform Linter CLI",
    "documentationURL": "https://github.com/yousysadmin/devcontainer-features/tflint",
    "installsAfter": [
        "ghcr.io/yousysadmin/devcontainer-features/common-utils"
    ],
    "options": {
        "version": {
            "type": "string",
            "proposals": [
                "v0.51.1",
                "latest"
            ],
            "default": "latest",
            "description": "Select the TFLint version you would like to install"
        }
    }
}
