{
    "id": "ansible",
    "version": "0.0.1",
    "name": "Ansible",
    "documentationURL": "https://github.com/yousysadmin/devcontainer-features/tree/master/src/ansible",
    "description": "Installs ansible-core and ansible-lint into an isolated venv at /usr/local/share/ansible-venv, with binaries symlinked into /usr/local/bin.",
    "options": {
        "version": {
            "type": "string",
            "proposals": [
                "latest"
            ],
            "default": "latest",
            "description": "ansible-core version to install (e.g. '2.17.5'), or 'latest'."
        },
        "lintVersion": {
            "type": "string",
            "proposals": [
                "latest"
            ],
            "default": "latest",
            "description": "ansible-lint version to install (e.g. '24.9.0'), or 'latest'."
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.ansible"
            ]
        }
    },
    "installsAfter": [
        "ghcr.io/yousysadmin/devcontainer-features/common-utils"
    ]
}
