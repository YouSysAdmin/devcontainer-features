{
    "name": "Chamber",
    "id": "chamber",
    "version": "0.0.1",
    "description": "CLI for managing secrets",
    "documentationURL": "https://github.com/yousysadmin/devcontainer-features/chamber",
    "installsAfter": [
        "ghcr.io/yousysadmin/devcontainer-features/common-utils"
    ],
    "options": {
        "version": {
            "type": "string",
            "proposals": [
                "v2.14.1",
                "latest"
            ],
            "default": "latest",
            "description": "Select the Chamber version you would like to install"
        }
    }
}
